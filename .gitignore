# build_release.log and other transient build logs
*.log
# editor / script backups
*.bak

# ── graphify knowledge-graph output (local analysis artefact, not source) ──────
graphify-out/

# ── Marketing website (separate deliverable, lives beside the app but is NOT
#    part of the macOS build — kept out of the app repo history) ─────────────
website/
website-v1-backup/
aidrop-website/

# Swift Package Manager
.build/
.swiftpm/

# ── Secrets / credentials ──────────────────────────────────────────────────────
# (All API keys in this project are stored in macOS Keychain via KeychainManager,
#  not in files. This section is a safety net for common accidental additions.)
.env
.env.*
Secrets.swift
Secrets.plist
*APIKey*
*api_key*
*credentials*

# ── Claude Code ───────────────────────────────────────────────────────────────
# .claude/ contains Claude Code session data, conversation history, and
# temporary git worktrees. Like .vscode/ or .cursor/, it is local tooling
# and should not be committed.
# CLAUDE.md (the project brief) is intentionally tracked — it gives future
# AI sessions the full architectural context automatically.
.claude/

